# ─── REQUIRED ────────────────────────────────────────────────
OPENAI_API_KEY=your_key_here
CASEY_DB=casey_titan_v26.sqlite3

# ─── DEMO GATE (production) ──────────────────────────────────
# One free run per IP for public visitors.
CASEY_DEMO_LIMIT_PER_IP=1
CASEY_PUBLIC_DEMO_LIMIT=1

# Comma-separated emails that bypass the gate entirely (your accounts).
# Add your own here before deploying — defaults are for local dev only.
CASEY_ADMIN_EMAILS=test@yahoo.com,jim@yahoo.com,jai@yahoo.com,casey@yahoo.com

# Alternative: pass this header (x-casey-admin-key) to bypass without an email.
CASEY_ADMIN_KEY=

# ─── LOCAL DEV ───────────────────────────────────────────────
# Set to 1 on your local machine to disable all demo gates entirely.
# Set to 0 (or omit) in production on Render — gate will be live.
CASEY_LOCAL_DEMO=0

# ─── PAYMENTS (configure before charging customers) ──────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=

# ─── DEPLOYMENT ──────────────────────────────────────────────
# Set to 1 to unlock all exports without a run_id (Render private deploys only).
CASEY_DEMO_UNLOCK_EXPORTS=0
